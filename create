require_once("session.php"); 
require_once("included_functions.php");
require_once("database.php"); 

// --- THIS IS THE CRITICAL FIX ---
// Call your Database class's static method to get the PDO object
$pdo = Database::DBConnect(); 

// ... rest of your script logic ...

// 2. Handle Form Submission (INSERT Logic)
if ($_SERVER['REQUEST_METHOD'] === 'POST') {
    // 📢 Ensure all required fields are present
    if (isset($_POST['artist_id'], $_POST['stage_id'], $_POST['start_date'], $_POST['start_time'], $_POST['end_date'], $_POST['end_time'])) {
        
        $artist_id = $_POST['artist_id'];
        $stage_id = $_POST['stage_id'];
        
        // MariaDB DATETIME format: YYYY-MM-DD HH:MM:SS
        $start_time = $_POST['start_date'] . ' ' . $_POST['start_time'];
        $end_time = $_POST['end_date'] . ' ' . $_POST['end_time'];

        try {
            // Transaction for safely calculating the next PerformanceID and inserting the record
            $pdo->beginTransaction();

            // ⚠️ Since PerformanceID is not auto-incrementing in your schema, we must calculate the next ID.
            $stmt_next_id = $pdo->prepare("SELECT MAX(PerformanceID) FROM Performance");
            $stmt_next_id->execute();
            $max_id = $stmt_next_id->fetchColumn();
            $next_performance_id = $max_id + 1;

            // Prepare the INSERT statement (5 values required)
            $sql = "INSERT INTO Performance (PerformanceID, ArtistID, StageID, StartTime, EndTime) 
                    VALUES (:performance_id, :artist_id, :stage_id, :start_time, :end_time)";
            
            $stmt = $pdo->prepare($sql);
            
            // Execute the statement with bound parameters
            $stmt->execute([
                ':performance_id' => $next_performance_id,
                ':artist_id'      => $artist_id,
                ':stage_id'       => $stage_id,
                ':start_time'     => $start_time,
                ':end_time'       => $end_time
            ]);

            $pdo->commit();

            // Redirect back to the Read page (index.php) upon success
            header("Location: GreerMilestone4Read.php?success=created");
            exit;

        } catch (\PDOException $e) {
            $pdo->rollBack();
            $error = "Error creating performance: " . $e->getMessage();
        }
    } else {
        $error = "Please fill in all required fields.";
    }
}


// 3. Fetch data for dropdowns (REQUIRED FOR FOREIGN KEYS)
$artists = [];
$stages = [];

try {
    // Fetch all Artists
    $stmt_artists = $pdo->query("SELECT ArtistID, ArtistName FROM Artist ORDER BY ArtistName");
    $artists = $stmt_artists->fetchAll();

    // Fetch all Stages
    $stmt_stages = $pdo->query("SELECT StageID, StageName FROM Stage ORDER BY StageName");
    $stages = $stmt_stages->fetchAll();

} catch (\PDOException $e) {
    $error = "Failed to load dropdown data: " . $e->getMessage();
}

