<?php

// Include your required files
require_once("session.php"); 
require_once("included_functions.php");
require_once("database.php"); 

// --- THIS IS THE CRITICAL FIX ---
// Call your Database class's static method to get the PDO object
$pdo = Database::DBConnect(); 

// ... rest of your script logic ...

// Define the SQL query with a JOIN operation (required for Milestone 4)
// Joins Performance, Artist (via NATURAL JOIN), and Stage
$sql = "
    SELECT
        P.PerformanceID,    -- Included for backend Update/Delete links
        A.ArtistName,
        S.StageName,
        P.StartTime,
        P.EndTime
    FROM
        Performance P
    NATURAL JOIN 
        Artist A            -- Uses NATURAL JOIN for ArtistID = ArtistID
    INNER JOIN 
        Stage S ON P.StageID = S.StageID
    ORDER BY
        P.StartTime
    LIMIT 20;               -- Ensures at least 15 records are retrieved
";

try {
    $stmt = $pdo->query($sql);
    $performances = $stmt->fetchAll(PDO::FETCH_ASSOC);

} catch (\PDOException $e) {
    $error = "Error fetching performances: " . $e->getMessage();
    $performances = [];
}

